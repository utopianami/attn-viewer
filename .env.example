PORT=3000

# Login accounts. Keep real values only in local .env, never in git.
# JSON object where keys are usernames and values are passwords.
# Example: AUTH_USERS_JSON={"alice":"change-me","bob":"change-me-too"}
AUTH_USERS_JSON=

# Use the fixed ngrok domain you reserved.
# Example: NGROK_DOMAIN=https://attn-viewer.ngrok.app
NGROK_DOMAIN=

# Optional. If ngrok is already authenticated on this machine, this can stay blank.
NGROK_AUTHTOKEN=

# Optional Codex CLI settings for translation generation.
# CODEX_BIN=codex
# CODEX_MODEL=
# CODEX_NOTE_FAST_MODEL=
# CODEX_NOTE_DEEP_MODEL=gpt-5.5
# CODEX_TRANSLATION_TIMEOUT_MS=240000
# CODEX_NOTE_TIMEOUT_MS=180000
